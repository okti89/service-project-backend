R2_ENABLED=False
SERVE_MEDIA_WITH_DJANGO=True
SECURE_HSTS_SECONDS=31536000
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mailer@example.com
EMAIL_HOST_PASSWORD=replace-me
DEFAULT_FROM_EMAIL=mailer@example.com
GOOGLE_MAPS_KEY=
MAPS_MONTHLY_QUOTA=1000
